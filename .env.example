# Root .env.example — copy to .env and fill values
# Each app has its own .env.example in apps/api/, apps/web/ etc.

# ─── Docker Compose overrides (optional — defaults in infra/docker/.env.docker) ─
POSTGRES_DB=ccip
POSTGRES_USER=ccip_owner
POSTGRES_PASSWORD=ccip_dev_pass
POSTGRES_PORT=5432

PGBOUNCER_PORT=5433

REDIS_PASSWORD=ccip_redis_dev
REDIS_PORT=6379

MINIO_ROOT_USER=ccip_minio
MINIO_ROOT_PASSWORD=ccip_minio_dev_pass
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

SMTP_PORT=1025
MAILHOG_UI_PORT=8025
