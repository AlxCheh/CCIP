# ─── Database (ADR-001: pool_mode=session via PgBouncer) ─────────────────────
# Direct to Postgres (for migrations)
DATABASE_URL="postgresql://ccip_owner:ccip_dev_pass@localhost:5432/ccip?schema=public"
# Via PgBouncer (for application — uncomment and add pgbouncer=true for production)
# DATABASE_URL="postgresql://ccip_owner:ccip_dev_pass@localhost:5433/ccip?schema=public&pgbouncer=true"

# ─── Redis (ADR-005: AOF required in production) ──────────────────────────────
REDIS_URL="redis://:ccip_redis_dev@localhost:6379"

# ─── Auth (ADR-009) ───────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── S3 / MinIO ───────────────────────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="ccip_minio"
S3_SECRET_KEY="ccip_minio_dev_pass"
S3_BUCKET="ccip-files"
S3_REGION="us-east-1"

# ─── SMTP (MailHog in dev) ────────────────────────────────────────────────────
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="noreply@ccip.dev"

# ─── BullMQ worker role (ADR-005) ────────────────────────────────────────────
# 'api' = HTTP server only; 'worker' = SLA scheduler + MV refresh processor
WORKER_ROLE="api"

# ─── Application ─────────────────────────────────────────────────────────────
PORT="3000"
NODE_ENV="development"
CORS_ORIGINS="http://localhost:5173"

# ─── Firebase Cloud Messaging (ADR-014) ──────────────────────────────────────
FCM_PROJECT_ID=""
FCM_PRIVATE_KEY=""
FCM_CLIENT_EMAIL=""
